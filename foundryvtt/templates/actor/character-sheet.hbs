        <li class="items-header">
          <div class="item-image">Icon</div>
          <div class="item-name">Name</div>
          <div class="energy-display">Primary</div>
          <div class="energy-display">Supporting</div>
          <div class="item-detail">Total</div>
          <div class="item-controls">Actions</div>
        </li>
        {{#each weaves as |item id|}}
        <li class="item-collapsible" data-item-id="{{item._id}}">
          
          {{!-- Item Header (Always Visible, Clickable) --}}
          <div class="item-header" data-action="expandItem">
            <i class="item-caret fas fa-caret-right"></i>
            <div class="item-image">
              <img src="{{item.img}}" title="{{item.name}}" width="24" height="24"/>
            </div>
            
            {{!-- Weave Info Container --}}
            <div class="weave-info">
              <span class="item-name-clickable">{{item.name}}</span>
              <div class="weave-meta">
                {{#if item.system.weaveType}}
                  <span class="weave-type">{{item.system.weaveType}}</span>
                {{/if}}
                {{#if item.system.actionCost}}
                  <span class="weave-cost">[{{item.system.actionCost}} actions]</span>
                {{/if}}
              </div>
            </div>
            
            {{!-- Primary Energy --}}
            <div class="energy-display">
              {{#if item.system.energyCost.primary.type}}
                <img src="systems/legends/images/icons/magic/{{item.system.energyCost.primary.type}}.svg" 
                     class="energy-icon energy-{{item.system.energyCost.primary.type}}"
                     width="26" height="26" title="{{capitalize item.system.energyCost.primary.type}}"/>
                {{item.system.energyCost.primary.cost}}
              {{else}}—{{/if}}
            </div>
            
            {{!-- Supporting Energy --}}
            <div class="energy-display">
              {{#if item.system.energyCost.supporting.type}}
                <img src="systems/legends/images/icons/magic/{{item.system.energyCost.supporting.type}}.svg" 
                     class="energy-icon energy-{{item.system.energyCost.supporting.type}}"
                     width="26" height="26" title="{{capitalize item.system.energyCost.supporting.type}}"/>
                {{item.system.energyCost.supporting.cost}}
              {{else}}—{{/if}}
            </div>
            
            {{!-- Total Cost --}}
            <div class="item-detail weave-total-cost">
              {{#if item.system.totalEnergyCost}}
                {{item.system.totalEnergyCost}}
              {{else}}
                {{add item.system.energyCost.primary.cost item.system.energyCost.supporting.cost}}
              {{/if}}
            </div>
            
            {{!-- Item Controls --}}
            <div class="item-controls">
              <a class="item-control" data-action="itemRoll" title="Cast Weave"><i class="fas fa-dice-d8"></i></a>
              <a class="item-control" data-action="itemChat" title="Post to Chat"><i class="fas fa-comment"></i></a>
              <a class="item-control" data-action="itemEdit" title="Edit"><i class="fas fa-edit"></i></a>
              <a class="item-control" data-action="itemDelete" title="Delete"><i class="fas fa-trash"></i></a>
            </div>
          </div>
          
          {{!-- Collapsible Content (Dynamic Loading) --}}
          <div class="item-summary">
            {{!-- Content will be generated dynamically by JavaScript --}}
          </div>
          
        </li>
        {{/each}}
      </ol>
    </div>
