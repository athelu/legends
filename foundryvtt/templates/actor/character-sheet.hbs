                Click the button below to begin the guided setup process. 
                You will choose your affinities, roll for potentials, and configure your magical abilities.
              </p>
              
              <button type="button" class="setup-magical-traits-btn" data-action="setupMagicalTraits">
                <i class="fas fa-magic"></i> Begin Magical Trait Setup
              </button>
            </div>
          </div>
        {{/if}}
      </div>
      {{/if}}
      
      <div class="inventory-header">
        <h3>Weaves</h3>
        <button type="button" data-action="openCompendium" data-type="weave" title="Add from Compendium">
          <i class="fas fa-atlas"></i> Add Weave
        </button>
      </div>
      
      {{!-- Weaves List --}}
