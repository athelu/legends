              {{/if}}
            </div>
            
            <div class="item-quantity">
              <input type="number" 
                     name="items.{{item._id}}.system.quantity" 
                     value="{{item.system.quantity}}" 
                     data-item-id="{{item._id}}"
                     data-item-field="quantity"
                     data-dtype="Number" 
                     min="0"
                     style="width: 60px !important; max-width: 60px !important; padding: 3px 6px !important; text-align: center !important; border: 1px solid #cbd5e0 !important; border-radius: 3px !important; background: white !important; font-weight: bold !important; color: #2d3748 !important; font-size: 13px !important; box-shadow: none !important; height: auto !important;"
                     onclick="event.stopPropagation()"/>
            </div>

            <div class="item-location">
              {{#if item.isContainer}}
              <span class="item-location-label">Container</span>
              {{else if item.canAssignContainer}}
              <select name="items.{{item._id}}.system.encumbrance.containerId"
                      data-item-id="{{item._id}}"
                      data-item-field="encumbrance.containerId"
                      onclick="event.stopPropagation()">
                <option value="">Not stored</option>
                {{#each item.storageOptions as |option|}}
                <option value="{{option.id}}" {{#if option.selected}}selected{{/if}}>{{option.name}}</option>
                {{/each}}
              </select>
              {{else}}
              <span class="item-location-label">Not stored</span>
              {{/if}}
            </div>

            <div class="item-capacity">
              {{#if item.isContainer}}
              <span class="item-capacity-value {{#if item.isOverCapacity}}over-capacity{{/if}}" title="{{#if item.containerStatus.overflowWeight}}{{item.containerStatus.overflowWeight}} lbs overflow{{/if}}">
                {{item.containerLoadDisplay}}
              </span>
              {{else}}
              <span class="item-capacity-value">{{item.effectiveWeightDisplay}}</span>
              {{/if}}
            </div>
            
            <div class="item-controls">
              {{#if item.isWearable}}
              <a class="item-control {{#if item.system.equipped}}equipped{{/if}}" data-action="itemEquip"
                title="{{#if item.system.equipped}}Equipped{{else}}Not Equipped{{/if}}">
                <i class="{{#if item.system.equipped}}fas{{else}}far{{/if}} fa-circle"></i>
              </a>
              {{/if}}
              <a class="item-control" data-action="itemChat" title="Post to Chat"><i class="fas fa-comment"></i></a>
              <a class="item-control" data-action="itemEdit" title="Edit"><i class="fas fa-edit"></i></a>
              <a class="item-control" data-action="itemDelete" title="Delete"><i class="fas fa-trash"></i></a>
            </div>
          </div>
          
          {{!-- Collapsible Content (Dynamic Loading) --}}
          <div class="item-summary">
            {{!-- Content will be generated dynamically by JavaScript --}}
          </div>
          
        </li>
        {{/each}}
      </ol>
    </div>

    {{!-- Biography Tab --}}
    <div class="tab biography" data-group="primary" data-tab="biography">
      <div class="language-management-panel">
        <h3>Languages</h3>
        <p class="creation-lock-note">Languages are tracked on the actor. Nationality sets the native language, and Language skill ranks grant additional selectable languages.</p>
        <div class="resource-row language-row">
          <label>Native</label>
          <span class="wealth-value">{{#if system.languages.nativeLabel}}{{system.languages.nativeLabel}}{{else}}Unassigned{{/if}}</span>
        </div>
        <div class="resource-row language-row">
          <label>Known</label>
          <span class="wealth-value">{{#if system.languages.display}}{{system.languages.display}}{{else}}No languages selected{{/if}}</span>
        </div>
        <div class="language-selection-header">
          <h4>Additional Languages</h4>
          <span class="language-selection-count">{{additionalLanguageCount}} / {{system.languages.capacity}} selected</span>
        </div>
        <div class="language-choice-grid">
          {{#each languageOptions}}
          <button
            type="button"
            class="language-choice-chip{{#if isNative}} is-native{{/if}}{{#if isSelected}} is-selected{{/if}}"
            data-action="toggleLanguageOption"
            data-language-key="{{key}}"
            title="{{description}}"
            {{#if isNative}}disabled{{/if}}
            {{#if isDisabled}}disabled{{/if}}>
            <span class="language-choice-label">{{label}}</span>
            {{#if isNative}}<span class="language-choice-meta">Native</span>{{/if}}
            {{#if isSelected}}<span class="language-choice-meta">Selected</span>{{/if}}
          </button>
          {{/each}}
        </div>
        <p class="creation-lock-note">Your Language skill grants {{system.languages.capacity}} additional language slot{{#unless (eq system.languages.capacity 1)}}s{{/unless}} beyond your native language.</p>
      </div>
      {{editor enrichedBiography target="system.biography.value" button=true owner=owner editable=editable}}
    </div>
  </section>
</form>
