<form class="{{cssClass}} flexcol" autocomplete="off">
  
  {{!-- Header --}}
  <header class="sheet-header">
    <img class="profile-img" src="{{actor.img}}" data-edit="img" title="{{actor.name}}" height="100" width="100"/>
    <div class="header-info">
      <div class="info-line">
        <label>Name:</label>
        <input name="name" type="text" value="{{actor.name}}" placeholder="Character Name"/>
      </div>
      <div class="info-line">
        <label>Background:</label>
        <div class="header-choice-group">
          {{#if primaryBackground}}
          <span class="derived-field" title="From background item">{{primaryBackground.name}}</span>
          {{else}}
          <input type="text" name="system.biography.background" value="{{system.biography.background}}" placeholder="Background"/>
          {{/if}}
          {{#if canChangeOriginChoices}}
          <button type="button" class="header-choice-button" data-action="changeHeaderChoice" data-item-type="background">{{#if primaryBackground}}Change{{else}}Choose{{/if}}</button>
          {{/if}}
        </div>
      </div>
      <div class="info-line">
        <label>Ancestry:</label>
        <div class="header-choice-group">
          {{#if primaryAncestry}}
          <span class="derived-field" title="From ancestry item">{{primaryAncestry.name}}</span>
          {{else}}
          <input type="text" name="system.biography.ancestry" value="{{system.biography.ancestry}}" placeholder="Ancestry"/>
          {{/if}}
          {{#if canChangeOriginChoices}}
          <button type="button" class="header-choice-button" data-action="changeHeaderChoice" data-item-type="ancestry">{{#if primaryAncestry}}Change{{else}}Choose{{/if}}</button>
          {{/if}}
        </div>
      </div>
      <div class="info-line">
        <label>Nationality:</label>
        <div class="header-choice-group">
          {{#if originLabel}}
          <span class="derived-field" title="Nationality determines native language">{{originLabel}}</span>
          {{else}}
          <span class="derived-field" title="Nationality determines native language">Not selected</span>
          {{/if}}
          {{#if canChangeOriginChoices}}
          <button type="button" class="header-choice-button" data-action="changeOrigin">{{#if originLabel}}Change{{else}}Choose{{/if}}</button>
          {{/if}}
        </div>
      </div>
      <div class="info-line">
        <label>Languages:</label>
        <div class="header-choice-group">
          <span class="derived-field" title="Known languages are tracked from nationality and Language skill ranks">{{#if system.languages.display}}{{system.languages.display}}{{else}}No languages assigned{{/if}}</span>
        </div>
      </div>
      <div class="info-line">
        <label>Tier:</label>
        <span class="tier-display">{{tier.current}}</span>
        <label class="xp-label">Total XP:</label>
        <input type="number" name="system.tier.xp" value="{{tier.xp}}" data-dtype="Number" class="xp-input" title="{{xpFieldHint}}" {{#unless canEditXpFields}}readonly{{/unless}}/>
        <label class="xp-label">Unspent XP:</label>
        <input type="number" name="system.tier.unspent" value="{{progression.unspent}}" data-dtype="Number" class="xp-input" title="{{xpFieldHint}}" {{#unless canEditXpFields}}readonly{{/unless}}/>
      </div>
      <div class="info-line progression-line">
        <label>Mode:</label>
        <span class="progression-badge">{{progression.phaseLabel}}</span>
        {{#if progression.manualOverride}}
        <span class="progression-badge warning">Manual Override</span>
        {{/if}}
        {{#if canAwardXp}}
        <button type="button" class="progression-button" data-action="awardXp">Award XP</button>
        {{/if}}
        {{#if canSpendXp}}
        <button type="button" class="progression-button" data-action="spendXp">Spend XP</button>
        {{/if}}
      </div>
      {{#if canManageProgression}}
      <div class="info-line progression-line">
        <label>Controls:</label>
        <button type="button" class="progression-button" data-action="toggleProgressionPhase">{{progression.nextPhaseLabel}}</button>
        <button type="button" class="progression-button" data-action="toggleManualOverride">{{#if progression.manualOverride}}Disable Manual Override{{else}}Enable Manual Override{{/if}}</button>
      </div>
      {{/if}}
    </div>
  </header>

  {{!-- Sheet Tab Navigation --}}
  <nav class="sheet-tabs tabs" data-group="primary">
    <a class="item" data-tab="main">Main</a>
    <a class="item" data-tab="weapons">Weapons</a>
    <a class="item" data-tab="actions">Actions</a>
    {{#if system.magicalTrait.type}}
    <a class="item" data-tab="magic">Magic</a>
    {{/if}}
    <a class="item" data-tab="features">Features</a>
    <a class="item" data-tab="effects">Effects</a>
    <a class="item" data-tab="equipment">Equipment</a>
    <a class="item" data-tab="biography">Biography</a>
  </nav>

  {{!-- Sheet Body --}}
  <section class="sheet-body">
    
    {{!-- Main Tab --}}
    <div class="tab main" data-group="primary" data-tab="main">
      <div class="main-layout">
        {{!-- Left Column: Skills --}}
        <div class="skills-column">
          <div class="skills-header">
            <h3>Skills</h3>
            <button type="button" class="skills-reference-button" data-action="openCompendium" data-compendium="rules" data-entry-name="Skills Reference" title="Open the skills rules reference">
              <i class="fas fa-book-open"></i>
              <span>Reference</span>
            </button>
          </div>
          <div class="skills-list">
            {{#each skillList}}
            <div class="skill-row" data-skill="{{key}}">
              <input type="checkbox" class="training-checkbox" data-action="toggleTrainingCheckbox" data-training-type="skill" data-training-key="{{key}}" {{checked checked}} title="Training checkbox for {{label}}"/>
              <label class="skill-name">{{label}}</label>
              <span class="skill-attr">&lt;{{attr}}&gt;</span>
              <input type="number" name="system.skills.{{key}}" value="{{base}}" data-dtype="Number" class="skill-base {{#unless ../canEditAdvancementFields}}readonly-field{{/unless}}" {{#unless ../canEditAdvancementFields}}readonly title="Locked outside character creation or manual override"{{/unless}}/>
              <span class="skill-bonus" title="{{breakdown}}">{{#if (gt bonus 0)}}+{{/if}}{{bonus}}</span>
              <span class="skill-total" title="Total = Base + Bonus\nBase: {{base}}\nBonus: {{bonus}}\n{{breakdown}}">{{total}}</span>
              <button type="button" data-action="skillRoll" data-skill="{{key}}" title="Roll {{label}}">
                <i class="fas fa-dice-d8"></i>
              </button>
            </div>
            {{/each}}
          </div>
        </div>

        {{!-- Right Column: Attributes & Resources --}}
        <div class="stats-column">
          <h3>Attributes</h3>
          <div class="attributes-list">
            {{#each attributeList as |attr|}}
            <div class="attribute-row" data-attribute="{{attr.key}}">
              <label>{{attr.label}}</label>
              <input type="number" name="system.attributes.{{attr.key}}.value" value="{{attr.base}}" data-dtype="Number" class="attribute-value {{#unless ../canEditAdvancementFields}}readonly-field{{/unless}}" {{#unless ../canEditAdvancementFields}}readonly title="Locked outside character creation or manual override"{{/unless}}/>
              <span class="attribute-bonus" title="{{attr.breakdown}}">{{#if (gt attr.bonus 0)}}+{{/if}}{{attr.bonus}}</span>
              <span class="attribute-total" title="Total = Base + Bonus\nBase: {{attr.base}}\nBonus: {{attr.bonus}}\n{{attr.breakdown}}">{{attr.total}}</span>
            </div>
            {{/each}}
          </div>

          <h3>Resources</h3>
          <div class="resources-section">
            {{!-- HP --}}
            <div class="resource-row hp-row">
              <label>HP</label>
              <input type="number" name="system.hp.value" value="{{system.hp.value}}" data-dtype="Number" class="resource-current"/>
              <span class="sep">/</span>
              <span class="resource-max">{{system.hp.max}}</span>
              <div class="temp-hp-section">
                <label class="temp-label">Temp:</label>
                <input type="number" name="system.hp.temp" value="{{system.hp.temp}}" data-dtype="Number" class="temp-hp-input" placeholder="0"/>
              </div>
            </div>

            {{!-- Luck --}}
            <div class="resource-row luck-row">
              <label>Luck</label>
              <input type="number" name="system.luck.current" value="{{system.luck.current}}" data-dtype="Number" class="resource-current"/>
              <span class="sep">/</span>
              <span class="resource-max">{{system.luck.max}}</span>
            </div>

            {{!-- Energy (if caster) --}}
            {{#if system.magicalTrait.type}}
            {{#unless isAlchemicalTradition}}
            <div class="resource-row energy-row">
              <label>Energy</label>
              <input type="number" name="system.energy.current" value="{{system.energy.current}}" data-dtype="Number" class="resource-current"/>
              <span class="sep">/</span>
              <span class="resource-max">{{system.energy.max}}</span>
            </div>
            {{/unless}}
            {{/if}}

            {{!-- DR --}}
            <div class="resource-row dr-row">
              <label>DR</label>
              <span class="dr-value">{{system.dr.total}}</span>
            </div>

            <div class="resource-row wealth-row coins-row">
              <label>Coins</label>
              <div class="coin-inputs">
                <div class="coin-group">
                  <span class="coin-label">gp</span>
                  <input type="number" name="system.currency.gp" value="{{system.currency.gp}}" data-dtype="Number" class="resource-current" min="0" />
                </div>
                <div class="coin-group">
                  <span class="coin-label">sp</span>
                  <input type="number" name="system.currency.sp" value="{{system.currency.sp}}" data-dtype="Number" class="resource-current" min="0" />
                </div>
                <div class="coin-group">
                  <span class="coin-label">cp</span>
                  <input type="number" name="system.currency.cp" value="{{system.currency.cp}}" data-dtype="Number" class="resource-current" min="0" />
                </div>
              </div>
            </div>

            <div class="resource-row wealth-row">
              <label>Coin Value</label>
              <span class="wealth-value" title="{{system.wealth.coins.totalGp}} gp total">{{system.wealth.coins.display}}</span>
            </div>

            <div class="resource-row wealth-row">
              <label>Gear Value</label>
              <span class="wealth-value" title="{{system.wealth.equipment.itemCount}} items counted, {{system.wealth.equipment.totalGp}} gp total">{{system.wealth.equipment.display}}</span>
            </div>

            <div class="resource-row wealth-row total-wealth-row">
              <label>Total Wealth</label>
              <span class="wealth-value" title="{{system.wealth.total.totalGp}} gp total">{{system.wealth.total.display}}</span>
            </div>

            <div class="resource-row encumbrance-row">
              <label>Load</label>
              <span class="wealth-value">{{system.encumbrance.effectiveWeight}} lbs</span>
            </div>

            <div class="resource-row encumbrance-row">
              <label>Status</label>
              <span class="wealth-value {{system.encumbrance.tier}}">{{system.encumbrance.tierLabel}}</span>
            </div>

            <div class="resource-row encumbrance-row">
              <label>Limits</label>
              <span class="wealth-value" title="Unencumbered {{system.encumbrance.thresholds.unencumbered}} lbs, Encumbered {{system.encumbrance.thresholds.encumbered}} lbs, Heavily Encumbered {{system.encumbrance.thresholds.heavilyEncumbered}} lbs, Maximum {{system.encumbrance.thresholds.max}} lbs">
                U {{system.encumbrance.thresholds.unencumbered}} / E {{system.encumbrance.thresholds.encumbered}} / H {{system.encumbrance.thresholds.heavilyEncumbered}}
              </span>
            </div>
          </div>

          {{!-- Rest Buttons --}}
          <div class="rest-buttons">
            <button type="button" data-action="shortRest" title="Short Rest (1 hour): Regain Con HP + 1 Luck">
              <i class="fas fa-moon"></i> Short Rest
            </button>
            <button type="button" data-action="longRest" title="Long Rest (8 hours): Regain (Con × 4) HP, restore all Luck & Energy">
              <i class="fas fa-bed"></i> Long Rest
            </button>
          </div>
        </div>
      </div>
    </div>

    {{!-- Weapons Tab   --}}
    <div class="tab weapons" data-group="primary" data-tab="weapons">
      <div class="inventory-header">
        <h3>Weapons</h3>
        <button type="button" data-action="openCompendium" data-type="weapon" title="Add Weapon">
          <i class="fas fa-plus"></i> Add
        </button>
      </div>
      
      <ol class="items-list weapon-list">
        <li class="items-header">
          <div class="item-image"></div>
          <div class="item-name">Name</div>
          <div class="item-attack">Attack</div>
          <div class="item-damage">Damage</div>
          <div class="item-controls">Actions</div>
        </li>
        
        {{#each weapons as |item id|}}
        <li class="item-collapsible" data-item-id="{{item._id}}">
          
          {{!-- Item Header (Always Visible, Clickable) --}}
          <div class="item-header" data-action="expandItem">
            <i class="item-caret fas fa-caret-right"></i>
            <div class="item-image">
              <img src="{{item.img}}" title="{{item.name}}" width="24" height="24"/>
            </div>
            
            <h4 class="item-name">{{item.name}}</h4>
            
            <div class="item-attack">
              {{!-- Show attack buttons based on attack modes --}}
              {{#each item.system.attackModes as |mode modeIndex|}}
                {{#if (eq mode.type "melee")}}
                  <button type="button" 
                          class="weapon-attack-btn melee-attack" data-action="weaponAttack" 
                          data-mode-index="{{modeIndex}}"
                          title="Melee Attack">
                    <i class="fas fa-hand-fist"></i>
                  </button>
                {{/if}}
                {{#if (or (eq mode.type "ranged") (eq mode.type "thrown"))}}
                  <button type="button" 
                          class="weapon-attack-btn ranged-attack" data-action="weaponAttack" 
                          data-mode-index="{{modeIndex}}"
                          title="{{#if (eq mode.type 'thrown')}}Throw{{else}}Ranged Attack{{/if}}">
                    <i class="fas fa-bullseye"></i>
                  </button>
                {{/if}}
              {{/each}}
            </div>
            
            <div class="item-damage">
              {{item.system.damage.base}} {{item.system.damage.type}}
            </div>
            
            <div class="item-controls">
              <a class="item-control {{#if item.system.equipped}}equipped{{/if}}" data-action="itemEquip"
                title="{{#if item.system.equipped}}Equipped{{else}}Not Equipped{{/if}}">
                <i class="{{#if item.system.equipped}}fas{{else}}far{{/if}} fa-circle"></i>
              </a>
              <a class="item-control" data-action="itemEdit" title="Edit"><i class="fas fa-edit"></i></a>
              <a class="item-control" data-action="itemDelete" title="Delete"><i class="fas fa-trash"></i></a>
            </div>
          </div>
          
          {{!-- Collapsible Content (Dynamic Loading) --}}
          <div class="item-summary">
            {{!-- Content will be generated dynamically by JavaScript --}}
          </div>
          
        </li>
        {{/each}}
      </ol>
    </div>

    {{!-- Actions Tab --}}
    <div class="tab actions" data-group="primary" data-tab="actions">
      <div class="inventory-header">
        <h3>Actions & Reactions</h3>
        <button type="button" data-action="openCompendium" data-type="action" title="Add from Compendium">
          <i class="fas fa-book"></i> Add from Compendium
        </button>
      </div>

      {{!-- Combat Actions --}}
      {{#if (hasItems combatActions)}}
      <div class="action-section">
        <h4>Combat Actions</h4>
        <ol class="items-list action-list">
          {{#each combatActions as |item id|}}
          <li class="item-collapsible" data-item-id="{{item._id}}">
            
            {{!-- Item Header (Always Visible, Clickable) --}}
            <div class="item-header" data-action="expandItem">
              <i class="item-caret fas fa-caret-right"></i>
              <div class="item-image">
                <img src="{{item.img}}" title="{{item.name}}" width="24" height="24"/>
              </div>
              <h4 class="item-name">{{item.name}}</h4>
              <div class="item-detail action-cost">
                {{#if item.system.actionCost}}[{{item.system.actionCost}}]{{/if}}
              </div>
              <div class="item-controls">
                <a class="item-control" data-action="itemChat" title="Post to Chat"><i class="fas fa-comment"></i></a>
                <a class="item-control" data-action="itemEdit" title="Edit"><i class="fas fa-edit"></i></a>
                <a class="item-control" data-action="itemDelete" title="Delete"><i class="fas fa-trash"></i></a>
              </div>
            </div>
            
            {{!-- Collapsible Content (Dynamic Loading) --}}
            <div class="item-summary">
              {{!-- Content dynamically loaded --}}
            </div>
          </li>
          {{/each}}
        </ol>
      </div>
      {{/if}}

      {{!-- Movement Actions --}}
      {{#if (hasItems movementActions)}}
      <div class="action-section">
        <h4>Movement Actions</h4>
        <ol class="items-list action-list">
          {{#each movementActions as |item id|}}
          <li class="item-collapsible" data-item-id="{{item._id}}">
            
            {{!-- Item Header (Always Visible, Clickable) --}}
            <div class="item-header" data-action="expandItem">
              <i class="item-caret fas fa-caret-right"></i>
              <div class="item-image">
                <img src="{{item.img}}" title="{{item.name}}" width="24" height="24"/>
              </div>
              <h4 class="item-name">{{item.name}}</h4>
              <div class="item-detail action-cost">
                {{#if item.system.actionCost}}[{{item.system.actionCost}}]{{/if}}
              </div>
              <div class="item-controls">
                <a class="item-control" data-action="itemChat" title="Post to Chat"><i class="fas fa-comment"></i></a>
                <a class="item-control" data-action="itemEdit" title="Edit"><i class="fas fa-edit"></i></a>
                <a class="item-control" data-action="itemDelete" title="Delete"><i class="fas fa-trash"></i></a>
              </div>
            </div>
            
            {{!-- Collapsible Content (Dynamic Loading) --}}
            <div class="item-summary">
              {{!-- Content dynamically loaded --}}
            </div>
          </li>
          {{/each}}
        </ol>
      </div>
      {{/if}}

      {{!-- Activate Actions --}}
      {{#if (hasItems activateActions)}}
      <div class="action-section">
        <h4>Activate Actions</h4>
        <ol class="items-list action-list">
          {{#each activateActions as |item id|}}
          <li class="item-collapsible" data-item-id="{{item._id}}">
            
            {{!-- Item Header (Always Visible, Clickable) --}}
            <div class="item-header" data-action="expandItem">
              <i class="item-caret fas fa-caret-right"></i>
              <div class="item-image">
                <img src="{{item.img}}" title="{{item.name}}" width="24" height="24"/>
              </div>
              <h4 class="item-name">{{item.name}}</h4>
              <div class="item-detail action-cost">
                {{#if item.system.actionCost}}[{{item.system.actionCost}}]{{/if}}
              </div>
              <div class="item-controls">
                <a class="item-control" data-action="itemChat" title="Post to Chat"><i class="fas fa-comment"></i></a>
                <a class="item-control" data-action="itemEdit" title="Edit"><i class="fas fa-edit"></i></a>
                <a class="item-control" data-action="itemDelete" title="Delete"><i class="fas fa-trash"></i></a>
              </div>
            </div>
            
            {{!-- Collapsible Content (Dynamic Loading) --}}
            <div class="item-summary">
              {{!-- Content dynamically loaded --}}
            </div>
          </li>
          {{/each}}
        </ol>
      </div>
      {{/if}}

      {{!-- Interact Actions --}}
      {{#if (hasItems interactActions)}}
      <div class="action-section">
        <h4>Interact Actions</h4>
        <ol class="items-list action-list">
          {{#each interactActions as |item id|}}
          <li class="item-collapsible" data-item-id="{{item._id}}">
            
            {{!-- Item Header (Always Visible, Clickable) --}}
            <div class="item-header" data-action="expandItem">
              <i class="item-caret fas fa-caret-right"></i>
              <div class="item-image">
                <img src="{{item.img}}" title="{{item.name}}" width="24" height="24"/>
              </div>
              <h4 class="item-name">{{item.name}}</h4>
              <div class="item-detail action-cost">
                {{#if item.system.actionCost}}[{{item.system.actionCost}}]{{/if}}
              </div>
              <div class="item-controls">
                <a class="item-control" data-action="itemChat" title="Post to Chat"><i class="fas fa-comment"></i></a>
                <a class="item-control" data-action="itemEdit" title="Edit"><i class="fas fa-edit"></i></a>
                <a class="item-control" data-action="itemDelete" title="Delete"><i class="fas fa-trash"></i></a>
              </div>
            </div>
            
            {{!-- Collapsible Content (Dynamic Loading) --}}
            <div class="item-summary">
              {{!-- Content dynamically loaded --}}
            </div>
          </li>
          {{/each}}
        </ol>
      </div>
      {{/if}}

      {{!-- Free Actions --}}
      {{#if (hasItems freeActions)}}
      <div class="action-section">
        <h4>Free Actions</h4>
        <ol class="items-list action-list">
          {{#each freeActions as |item id|}}
          <li class="item-collapsible" data-item-id="{{item._id}}">
            
            {{!-- Item Header (Always Visible, Clickable) --}}
            <div class="item-header" data-action="expandItem">
              <i class="item-caret fas fa-caret-right"></i>
              <div class="item-image">
                <img src="{{item.img}}" title="{{item.name}}" width="24" height="24"/>
              </div>
              <h4 class="item-name">{{item.name}}</h4>
              <div class="item-detail action-cost">
                {{#if item.system.actionCost}}[{{item.system.actionCost}}]{{/if}}
              </div>
              <div class="item-controls">
                <a class="item-control" data-action="itemChat" title="Post to Chat"><i class="fas fa-comment"></i></a>
                <a class="item-control" data-action="itemEdit" title="Edit"><i class="fas fa-edit"></i></a>
                <a class="item-control" data-action="itemDelete" title="Delete"><i class="fas fa-trash"></i></a>
              </div>
            </div>
            
            {{!-- Collapsible Content (Dynamic Loading) --}}
            <div class="item-summary">
              {{!-- Content dynamically loaded --}}
            </div>
          </li>
          {{/each}}
        </ol>
      </div>
      {{/if}}

      {{!-- Reactions --}}
      {{#if (hasItems reactions)}}
      <div class="action-section">
        <h4>Reactions</h4>
        <ol class="items-list action-list">
          {{#each reactions as |item id|}}
          <li class="item-collapsible" data-item-id="{{item._id}}">
            
            {{!-- Item Header (Always Visible, Clickable) --}}
            <div class="item-header" data-action="expandItem">
              <i class="item-caret fas fa-caret-right"></i>
              <div class="item-image">
                <img src="{{item.img}}" title="{{item.name}}" width="24" height="24"/>
              </div>
              <h4 class="item-name">{{item.name}}</h4>
              <div class="item-detail action-trigger">
                {{#if item.system.trigger}}<small>{{item.system.trigger}}</small>{{/if}}
              </div>
              <div class="item-controls">
                <a class="item-control" data-action="itemChat" title="Post to Chat"><i class="fas fa-comment"></i></a>
                <a class="item-control" data-action="itemEdit" title="Edit"><i class="fas fa-edit"></i></a>
                <a class="item-control" data-action="itemDelete" title="Delete"><i class="fas fa-trash"></i></a>
              </div>
            </div>
            
            {{!-- Collapsible Content (Dynamic Loading) --}}
            <div class="item-summary">
              {{!-- Content dynamically loaded --}}
            </div>
          </li>
          {{/each}}
        </ol>
      </div>
      {{/if}}
    </div>

    {{!-- Magic Tab --}}
    {{#if system.magicalTrait.type}}
    <div class="tab magic" data-group="primary" data-tab="magic">
      
      {{!-- Magical Trait Setup Section --}}
      {{#if system.magicalTrait.type}}
      <div class="magical-trait-section">
        <h3>Magical Powers</h3>
        
        {{#if system.magicalTrait.isSetup}}
          {{!-- Magical trait is configured - show stats --}}
          <div class="magic-stats-display">
            {{!-- Combined Potentials and Mastery Display --}}
            <div class="energy-header">
              <h4>Magical Energies</h4>
              <div class="magic-stats-inline">
                {{#if system.castingStat.displayLabel}}
                <div class="casting-stat-inline">
                  <label>Casting Stat:</label>
                  <span>{{system.castingStat.displayLabel}} {{system.castingStat.displayValue}}</span>
                </div>
                {{/if}}
                {{#unless isAlchemicalTradition}}
                <div class="channel-uses">
                  <label>Energy:</label>
                    <input type="number" name="system.energy.current" 
                      value="{{system.energy.current}}" data-dtype="Number" 
                         class="uses-input" min="0" max="{{system.energy.max}}"/>
                  <span class="sep">/</span>
                  <span class="max-value">{{system.energy.max}}</span>
                </div>
                {{/unless}}
                {{#if system.channelDivinity.max}}
                <div class="channel-uses">
                  <label>Channel Divinity:</label>
                  <input type="number" name="system.channelDivinity.current" 
                         value="{{system.channelDivinity.current}}" data-dtype="Number" 
                         class="uses-input" min="0" max="{{system.channelDivinity.max}}"/>
                  <span class="sep">/</span>
                  <span class="max-value">{{system.channelDivinity.max}}</span>
                </div>
                {{/if}}
              </div>
            </div>
            
            {{#if isAlchemicalTradition}}
            <div class="magic-setup-required">
              <div class="setup-info">
                <h4>Alchemical Preparation Rules</h4>
                <p>Use Craft: Alchemist and the downtime rules to create daily preparations, short rest preparations, field improvisations, and crafted preparations.</p>
              </div>
            </div>
            {{else}}
            <div class="energy-potentials-grid">
              {{#each system.potentials as |potential key|}}
              <div class="energy-row">
                <label class="energy-label">{{potential.label}}</label>
                <div class="energy-values">
                  <input type="checkbox" class="training-checkbox mastery-checkbox" data-action="toggleTrainingCheckbox" data-training-type="mastery" data-training-key="{{key}}" {{checked (lookup ../training.mastery key)}} title="Training checkbox for {{potential.label}} mastery"/>
                  <input type="number" name="system.mastery.{{key}}.value" 
                         value="{{lookup (lookup ../system.mastery key) 'value'}}" data-dtype="Number" 
                        min="0" max="10" class="energy-input {{#unless ../canEditAdvancementFields}}readonly-field{{/unless}}" title="Mastery"
                        {{#unless ../canEditAdvancementFields}}readonly{{/unless}}
                         placeholder="0"/>
                  <span class="separator">/</span>
                  <input type="number" name="system.potentials.{{key}}.value" 
                         value="{{potential.value}}" data-dtype="Number" 
                        min="0" max="10" class="energy-input {{#unless ../canEditAdvancementFields}}readonly-field{{/unless}}" title="Potential"
                        {{#unless ../canEditAdvancementFields}}readonly{{/unless}}
                         placeholder="0"/>
                </div>
              </div>
              {{/each}}
            </div>
            {{/if}}
          </div>
        {{else}}
