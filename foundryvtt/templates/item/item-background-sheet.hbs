<form class="{{cssClass}} flexcol" autocomplete="off">
  <header class="sheet-header">
    <img class="profile-img" src="{{item.img}}" data-edit="img" title="{{item.name}}" height="64" width="64"/>
    <div class="header-fields">
      <h1 class="charname"><input name="name" type="text" value="{{item.name}}" placeholder="Background Name"/></h1>
    </div>
  </header>

  <nav class="sheet-tabs tabs" data-group="primary">
    <a class="item" data-tab="description">Overview</a>
    <a class="item" data-tab="details">Details</a>
  </nav>

  <section class="sheet-body">
    <!-- Description Tab -->
    <div class="tab description" data-group="primary" data-tab="description">
      {{#if backgroundSummary.hasBenefits}}
      <div class="background-overview">
        <h3>Background Benefits</h3>

        {{#if backgroundSummary.startingXP}}
        <div class="form-group">
          <label>Starting XP</label>
          <div>+{{backgroundSummary.startingXP}} XP</div>
        </div>
        {{/if}}

        {{#if backgroundSummary.grantedSkills.length}}
        <div class="form-group">
          <label>Granted Skill Ranks</label>
          <div>
            {{#each backgroundSummary.grantedSkills}}
            <div>{{label}} {{amount}}</div>
            {{/each}}
          </div>
        </div>
        {{/if}}

        {{#if backgroundSummary.itemGrants.length}}
        <div class="form-group">
          <label>Starting Equipment</label>
          <div>
            {{#each backgroundSummary.itemGrants}}
            <div>{{label}}</div>
            {{/each}}
          </div>
        </div>
        {{/if}}

        {{#if backgroundSummary.features}}
        <div class="form-group">
          <label>Special Features</label>
          <div>{{backgroundSummary.features}}</div>
        </div>
        {{/if}}
      </div>
      {{/if}}

      <h3>Description</h3>
      {{editor enrichedDescription target="system.description.value" button=true owner=owner editable=editable}}
    </div>

    <!-- Details Tab -->
    <div class="tab details" data-group="primary" data-tab="details">
      
      <!-- Starting XP -->
      <div class="form-group">
        <label>Starting XP</label>
        <input type="number" name="system.startingXP" value="{{system.startingXP}}" data-dtype="Number" min="0" />
        <small>Applied to actor tier XP while this background is owned. Removed if the background is deleted.</small>
      </div>

      <!-- Skill Bonuses -->
      <h3>Skill Bonuses</h3>
      <div class="form-group">
        <label>Granted Skill Ranks</label>
        <textarea name="system.skillBonuses" rows="3" placeholder="Religion 3, Empathy 1, History 1, +36 XP">{{system.skillBonuses}}</textarea>
        <small>Use the human-readable rules text format. Structured actor grants are generated automatically when the item is saved.</small>
      </div>

      <!-- Starting Equipment -->
      <h3>Starting Equipment</h3>
      <div class="form-group">
        <label>Equipment List</label>
        <textarea name="system.startingEquipment" rows="5" placeholder="Iron Holy symbol, prayer book, robe, incense stick x10, common clothes, shoes">{{system.startingEquipment}}</textarea>
        <small>Comma-separated or one item per line. Linked starter items are added to the actor when the background is owned and removed when it is deleted.</small>
      </div>

      <!-- Suggested Feats -->
      <div class="form-group">
        <label>Suggested Feats</label>
        <textarea name="system.suggestedFeats" rows="3" placeholder="Feats that work well with this background">{{system.suggestedFeats}}</textarea>
      </div>

      <!-- Background Features -->
      <div class="form-group">
        <label>Special Features</label>
        <textarea name="system.features" rows="4" placeholder="Any special abilities or features granted by this background">{{system.features}}</textarea>
      </div>

      <!-- Sample Names -->
      <div class="form-group">
        <label>Sample Names (optional)</label>
        <textarea name="system.sampleNames" rows="2" placeholder="Appropriate names for characters with this background">{{system.sampleNames}}</textarea>
      </div>

      <!-- Characteristic Traits -->
      <div class="form-group">
        <label>Characteristic Traits</label>
        <textarea name="system.traits" rows="3" placeholder="Personality traits, ideals, bonds, or flaws common to this background">{{system.traits}}</textarea>
      </div>

      <!-- Special Notes -->
      <div class="form-group">
        <label>Special Notes</label>
        <textarea name="system.notes" rows="3" placeholder="Any additional information about this background">{{system.notes}}</textarea>
      </div>

    </div>
  </section>
</form>
