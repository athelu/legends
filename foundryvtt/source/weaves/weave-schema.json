{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://legends-ttrpg.com/schemas/weave.json",
  "title": "Legends TTRPG Weave Schema",
  "description": "Complete JSON Schema for weave items in the Legends TTRPG system. Includes base properties, success scaling, classification, and effects.",
  "type": "object",
  "required": ["name", "type", "system"],
  "properties": {
    "_id": {
      "type": "string",
      "description": "Unique identifier for the weave (auto-generated by Foundry)"
    },
    "name": {
      "type": "string",
      "description": "Display name of the weave",
      "minLength": 1
    },
    "type": {
      "type": "string",
      "const": "weave",
      "description": "Item type, always 'weave'"
    },
    "img": {
      "type": "string",
      "description": "Path to icon image",
      "default": "icons/magic/abjuration/abjuration-purple.webp"
    },
    "system": {
      "type": "object",
      "required": ["description", "energyCost", "actionCost"],
      "properties": {
        "description": {
          "type": "object",
          "description": "Formatted description with all weave details",
          "properties": {
            "value": {
              "type": "string",
              "description": "HTML formatted description including all weave properties"
            }
          },
          "required": ["value"]
        },
        "energyCost": {
          "$ref": "#/$defs/energyCost"
        },
        "range": {
          "type": "string",
          "description": "Range of the weave",
          "examples": [
            "Touch",
            "Self",
            "Close, 30 ft.",
            "Medium, 60 ft.",
            "Medium, 60 ft. (10-foot radius)",
            "Long, 120 ft.",
            "Unlimited (line of sight)"
          ]
        },
        "duration": {
          "type": "string",
          "description": "How long the weave effect lasts",
          "examples": [
            "Instantaneous",
            "1 minute",
            "10 minutes",
            "1 hour",
            "Until dismissed",
            "Concentration, up to 1 minute",
            "Permanent"
          ]
        },
        "target": {
          "type": "string",
          "description": "Target selection description",
          "default": ""
        },
        "savingThrow": {
          "type": "string",
          "description": "Type of saving throw required",
          "enum": ["", "none", "will", "fortitude", "reflex"],
          "default": ""
        },
        "effect": {
          "type": "string",
          "description": "Detailed effect description (often in description.value instead)",
          "default": ""
        },
        "effectType": {
          "type": "string",
          "description": "Category of effect",
          "enum": ["", "damage", "healing", "utility", "control", "buff", "debuff", "summon", "transformation", "protection", "divination"],
          "default": "damage"
        },
        "deliveryMethod": {
          "type": "string",
          "description": "How the weave mechanically resolves",
          "enum": ["attack", "save", "automatic"],
          "default": "save"
        },
        "weaveType": {
          "type": "string",
          "description": "Complexity/type of weave",
          "enum": ["simple", "complex", "intricate"],
          "default": "simple"
        },
        "actionCost": {
          "type": "number",
          "description": "Number of actions required to cast",
          "enum": [1, 2, 3],
          "default": 1
        },
        "damage": {
          "$ref": "#/$defs/damageProperties"
        },
        "successScaling": {
          "type": "string",
          "description": "Human-readable success scaling description (deprecated in favor of structured damage.scaling)",
          "default": ""
        },
        "targetingSuccessScaling": {
          "type": "string",
          "description": "Human-readable targeting success scaling description used by the two-roll weave workflow",
          "default": ""
        },
        "weavingRoll": {
          "type": "string",
          "description": "Which attributes to roll for weaving",
          "default": ""
        },
        "targetingRoll": {
          "type": "string",
          "description": "Which attributes/stat to roll for targeting or delivery",
          "default": ""
        },
        "appliesEffects": {
          "type": "array",
          "description": "Array of effects/conditions to apply when weave succeeds",
          "items": {
            "$ref": "#/$defs/appliedEffect"
          },
          "default": []
        },
        "tags": {
          "type": "array",
          "description": "Thematic and mechanical classification tags",
          "items": {
            "type": "string",
            "enum": [
              "necromantic",
              "forbidden",
              "illusion",
              "summoning",
              "divination",
              "teleportation",
              "healing",
              "offensive",
              "defensive",
              "utility",
              "buff",
              "debuff",
              "control",
              "aoe",
              "single-target",
              "multi-target",
              "self",
              "touch",
              "ranged",
              "zone",
              "wall",
              "construct",
              "ritual",
              "concentration"
            ]
          },
          "uniqueItems": true,
          "default": []
        }
      }
    },
    "effects": {
      "type": "array",
      "description": "Active effects array (usually empty, effects defined in appliesEffects instead)",
      "default": []
    },
    "_key": {
      "type": "string",
      "description": "LevelDB key for compendium storage"
    }
  },
  "$defs": {
    "energyCost": {
      "type": "object",
      "description": "Energy cost to cast the weave",
      "properties": {
        "primary": {
          "type": "object",
          "description": "Primary energy type and cost",
          "properties": {
            "type": {
              "type": "string",
              "description": "Primary energy type",
              "enum": [
                "variable-elemental",
                "fire",
                "water",
                "air",
                "earth",
                "positive",
                "negative",
                "space",
                "time",
                "force",
                "entropy"
              ]
            },
            "cost": {
              "type": "number",
              "description": "Amount of primary energy required",
              "minimum": 0
            }
          },
          "required": ["type", "cost"]
        },
        "supporting": {
          "type": "object",
          "description": "Supporting energy type and cost (optional)",
          "properties": {
            "type": {
              "type": "string",
              "description": "Supporting energy type (empty string if none)",
              "enum": [
                "",
                "variable-elemental",
                "fire",
                "water",
                "air",
                "earth",
                "positive",
                "negative",
                "space",
                "time",
                "force",
                "entropy"
              ]
            },
            "cost": {
              "type": "number",
              "description": "Amount of supporting energy required",
              "minimum": 0
            }
          },
          "required": ["type", "cost"]
        }
      },
      "required": ["primary", "supporting"]
    },
    "damageProperties": {
      "type": "object",
      "description": "Damage properties and success scaling",
      "properties": {
        "base": {
          "type": "number",
          "description": "Base damage at success level 2 (0 for non-damaging weaves)",
          "minimum": 0
        },
        "type": {
          "type": "string",
          "description": "Type of damage dealt",
          "enum": [
            "",
            "fire",
            "cold",
            "lightning",
            "acid",
            "sonic",
            "force",
            "negative",
            "positive",
            "necrotic",
            "radiant",
            "psychic",
            "poison",
            "thunder",
            "bludgeoning",
            "piercing",
            "slashing"
          ]
        },
        "drInteraction": {
          "type": "string",
          "description": "How damage interacts with damage reduction",
          "enum": ["", "full", "half", "none", "ignore"]
        },
        "scaling": {
          "$ref": "#/$defs/successScaling"
        }
      },
      "required": ["base", "type", "drInteraction", "scaling"]
    },
    "successScaling": {
      "type": "object",
      "description": "Success level scaling entries (0-5+). Each entry defines what happens at that net success level.",
      "patternProperties": {
        "^[0-9]+$": {
          "type": "object",
          "description": "Scaling entry for a specific success level (net successes = caster successes - target successes)",
          "properties": {
            "description": {
              "type": "string",
              "description": "Human-readable description of this success level's effect"
            },
            "appliesEffects": {
              "type": "boolean",
              "description": "Whether configured effects should be applied at this success level",
              "default": false
            },
            "damage": {
              "oneOf": [
                {
                  "type": "number",
                  "description": "Total damage dealt at this success level"
                },
                {
                  "type": "object",
                  "properties": {
                    "amount": {
                      "type": "number",
                      "description": "Amount of damage"
                    },
                    "type": {
                      "type": "string",
                      "description": "Damage type (fire, cold, etc.)"
                    },
                    "additionalTypes": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "amount": {"type": "number"},
                          "type": {"type": "string"}
                        },
                        "required": ["amount", "type"]
                      },
                      "description": "Additional damage types for compound damage"
                    }
                  },
                  "required": ["amount"]
                }
              ]
            },
            "healing": {
              "type": "number",
              "description": "HP healed at this success level",
              "minimum": 0
            },
            "duration": {
              "oneOf": [
                {
                  "type": "null",
                  "description": "No duration applies at this success level"
                },
                {
                  "type": "string",
                  "description": "Duration as text (e.g., 'full effect', 'until dispelled')"
                },
                {
                  "$ref": "#/$defs/structuredDuration"
                }
              ]
            },
            "range": {
              "$ref": "#/$defs/rangeObject"
            },
            "area": {
              "$ref": "#/$defs/areaObject"
            },
            "quantity": {
              "$ref": "#/$defs/quantityObject"
            },
            "capacity": {
              "$ref": "#/$defs/capacityObject"
            },
            "targetCount": {
              "type": "number",
              "description": "Number of targets that can be affected simultaneously",
              "minimum": 1
            },
            "pushDistance": {
              "$ref": "#/$defs/pushDistanceObject"
            },
            "effectType": {
              "type": "string",
              "description": "Specific effect/condition type at this level (e.g., 'frightened', 'fleeing', 'cowering')"
            },
            "specialMechanics": {
              "oneOf": [
                {
                  "type": "string",
                  "description": "Special rule or mechanic that applies at this success level"
                },
                {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "description": "Special rules or mechanics that apply at this success level"
                }
              ]
            },
            "drModifier": {
              "type": "number",
              "description": "DR (Damage Reduction) value added at this success level"
            },
            "hp": {
              "type": "number",
              "description": "HP value for constructs/walls at this success level",
              "minimum": 0
            },
            "notes": {
              "type": "string",
              "description": "Additional notes or clarifications"
            }
          },
          "required": ["description"]
        }
      },
      "additionalProperties": false
    },
    "appliedEffect": {
      "type": "object",
      "description": "Effect to apply when weave succeeds",
      "properties": {
        "effectId": {
          "type": "string",
          "description": "ID of the effect to apply (matches condition compendium entry)"
        },
        "params": {
          "type": "object",
          "description": "Additional parameters for the effect"
        }
      },
      "required": ["effectId", "params"]
    },
    "structuredDuration": {
      "type": "object",
      "description": "Structured duration object",
      "properties": {
        "value": {
          "type": "number",
          "description": "Numeric duration value"
        },
        "unit": {
          "type": "string",
          "enum": [
            "round",
            "minute",
            "hour",
            "day",
            "week",
            "month",
            "year",
            "permanent",
            "instantaneous"
          ],
          "description": "Time unit"
        }
      },
      "required": ["value", "unit"]
    },
    "rangeObject": {
      "type": "object",
      "description": "Range scaling object",
      "properties": {
        "value": {
          "type": "number",
          "description": "Numeric range value"
        },
        "unit": {
          "type": "string",
          "enum": ["feet", "mile", "miles"],
          "description": "Distance unit"
        }
      },
      "required": ["value", "unit"]
    },
    "areaObject": {
      "type": "object",
      "description": "Area effect object",
      "properties": {
        "shape": {
          "type": "string",
          "enum": ["radius", "cube", "square", "line", "cone", "sphere"],
          "description": "Area shape"
        },
        "size": {
          "type": "number",
          "description": "Size in feet"
        },
        "unit": {
          "type": "string",
          "enum": ["feet", "ft"],
          "default": "feet"
        }
      },
      "required": ["shape", "size"]
    },
    "quantityObject": {
      "type": "object",
      "description": "Quantity of items/effects",
      "properties": {
        "amount": {
          "type": "number",
          "description": "Quantity amount"
        },
        "unit": {
          "type": "string",
          "description": "What is being counted (e.g., 'darts', 'duplicates', 'gallons', 'questions')"
        }
      },
      "required": ["amount", "unit"]
    },
    "capacityObject": {
      "type": "object",
      "description": "Weight/mass capacity",
      "properties": {
        "weight": {
          "type": "number",
          "description": "Weight capacity in pounds"
        },
        "unit": {
          "type": "string",
          "enum": ["lbs", "pounds"],
          "default": "lbs"
        }
      },
      "required": ["weight"]
    },
    "pushDistanceObject": {
      "type": "object",
      "description": "Push/pull distance",
      "properties": {
        "distance": {
          "type": "number",
          "description": "Distance pushed/pulled in feet"
        },
        "unit": {
          "type": "string",
          "enum": ["feet", "ft"],
          "default": "feet"
        }
      },
      "required": ["distance"]
    }
  },
  "examples": [
    {
      "name": "Fireball - Damage weave with save",
      "description": "Typical damage-dealing AOE weave with saving throw and damage scaling",
      "data": {
        "_id": "aba0af23c11f4986",
        "name": "Fireball",
        "type": "weave",
        "img": "icons/magic/abjuration/abjuration-purple.webp",
        "system": {
          "description": {
            "value": "<p><strong>Primary Energy:</strong> Fire 5...</p>"
          },
          "weaveType": "complex",
          "actionCost": 2,
          "energyCost": {
            "primary": {"type": "fire", "cost": 5},
            "supporting": {"type": "space", "cost": 4}
          },
          "range": "Medium, 60 ft.",
          "duration": "Instantaneous",
          "savingThrow": "reflex",
          "deliveryMethod": "save",
          "effectType": "damage",
          "damage": {
            "base": 28,
            "type": "fire",
            "drInteraction": "half",
            "scaling": {
              "0": {"damage": 0, "description": "no damage", "appliesEffects": false},
              "1": {"damage": 14, "description": "half damage", "appliesEffects": false},
              "2": {"damage": 28, "description": "full damage", "appliesEffects": false},
              "3": {"damage": 36, "description": "enhanced", "appliesEffects": false},
              "4": {"damage": 44, "description": "critical", "appliesEffects": false},
              "5": {"damage": 52, "description": "extreme", "appliesEffects": true}
            }
          },
          "appliesEffects": [{"effectId": "ignited", "params": {}}],
          "tags": ["offensive", "aoe", "ranged"]
        }
      }
    },
    {
      "name": "Sleep - Effect weave with duration scaling",
      "description": "Non-damage weave that applies conditions with duration scaling by success level",
      "data": {
        "_id": "38331227122348ba",
        "name": "Sleep",
        "type": "weave",
        "system": {
          "weaveType": "complex",
          "actionCost": 2,
          "energyCost": {
            "primary": {"type": "positive", "cost": 3},
            "supporting": {"type": "space", "cost": 3}
          },
          "range": "Medium, 60 ft. (10-foot radius)",
          "duration": "1 minute (or until awakened)",
          "savingThrow": "will",
          "deliveryMethod": "save",
          "damage": {
            "base": 0,
            "type": "",
            "drInteraction": "",
            "scaling": {
              "0": {
                "description": "no effect",
                "appliesEffects": false,
                "duration": null
              },
              "1": {
                "description": "1 round",
                "appliesEffects": true,
                "duration": {"value": 1, "unit": "round"}
              },
              "2": {
                "description": "full effect",
                "appliesEffects": true,
                "duration": {"value": 1, "unit": "minute"}
              },
              "3": {
                "description": "10 minutes",
                "appliesEffects": true,
                "duration": {"value": 10, "unit": "minute"}
              },
              "4": {
                "description": "1 hour",
                "appliesEffects": true,
                "duration": {"value": 1, "unit": "hour"}
              },
              "5": {
                "description": "4 hours",
                "appliesEffects": true,
                "duration": {"value": 4, "unit": "hour"}
              }
            }
          },
          "appliesEffects": [{"effectId": "asleep-unconscious", "params": {}}],
          "tags": ["control", "aoe", "ranged"]
        }
      }
    },
    {
      "name": "Light - Automatic utility weave",
      "description": "Simple utility weave with no attack roll or saving throw",
      "data": {
        "name": "Light",
        "type": "weave",
        "system": {
          "weaveType": "simple",
          "actionCost": 1,
          "energyCost": {
            "primary": {"type": "positive", "cost": 1},
            "supporting": {"type": "", "cost": 0}
          },
          "range": "Touch",
          "duration": "1 hour",
          "savingThrow": "none",
          "deliveryMethod": "automatic",
          "effectType": "utility",
          "damage": {
            "base": 0,
            "type": "",
            "drInteraction": "",
            "scaling": {}
          },
          "appliesEffects": [],
          "tags": ["utility", "touch"]
        }
      }
    }
  ]
}
